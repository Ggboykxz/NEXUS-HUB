rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Les couvertures sont lisibles par tous, modifiables par l'auteur
    match /covers/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Les pages de chapitres
    match /chapters/{storyId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Profils utilisateurs
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}