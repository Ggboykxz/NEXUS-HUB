rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Profils utilisateurs
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      match /library/{storyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /favorites/{storyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /notifications/{notifId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /subscriptions/{artistId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /unlockedChapters/{chapterId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Histoires et Chapitres
    match /stories/{storyId} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.resource.data.artistId == request.auth.uid || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      
      match /chapters/{chapterId} {
        allow read: if true;
        allow write: if request.auth != null;
        
        match /comments/{commentId} {
          allow read: if true;
          allow write: if request.auth != null;
        }
      }
      match /likes/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Signalements (Admin seulement)
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Forums et Clubs
    match /forumThreads/{threadId} {
      allow read: if true;
      allow write: if request.auth != null;
      match /replies/{replyId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
    
    match /readingClubs/{clubId} {
      allow read: if true;
      allow write: if request.auth != null;
      match /members/{memberId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
      match /discussions/{discId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
      match /fanArts/{artId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Collections publiques
    match /products/{id} { allow read: if true; allow write: if false; }
    match /blogPosts/{id} { allow read: if true; allow write: if false; }
    match /festivals/{id} { allow read: if true; allow write: if false; }
    match /translationMissions/{id} { allow read: if true; allow write: if false; }
    match /masterclasses/{id} { allow read: if true; allow write: if false; }
    
    // Status de frappe
    match /typing/{convId} {
      allow read, write: if request.auth != null;
    }
    
    // Live events
    match /liveEvents/{eventId}/messages/{msgId} {
      allow read: if true;
      allow create: if request.auth != null;
    }
  }
}