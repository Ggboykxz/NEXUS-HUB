rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // RÈGLES POUR LES HISTOIRES
    match /stories/{storyId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == resource.data.artistId;

      // Sous-collection Commentaires (Validation de longueur 500 chars + Rate Limiting 30s)
      match /chapters/{chapterId}/comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null 
                      && request.resource.data.content is string
                      && request.resource.data.content.size() <= 500
                      && (
                        !('lastCommentAt' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) ||
                        request.time > get(/databases/$(database)/documents/users/$(request.auth.uid)).data.lastCommentAt + duration.value(30, 's')
                      );
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
      }
    }
    
    // RÈGLES POUR LES UTILISATEURS
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Sous-collection Bibliothèque
      match /library/{storyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Sous-collection Notifications
      match /notifications/{notifId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // RÈGLES POUR LE FORUM
    match /forumThreads/{threadId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.content.size() <= 2000;
      allow update: if request.auth != null && request.auth.uid == resource.data.authorId;
      
      match /replies/{replyId} {
        allow read: if true;
        allow create: if request.auth != null 
                      && request.resource.data.content is string
                      && request.resource.data.content.size() <= 500;
      }
    }
  }
}