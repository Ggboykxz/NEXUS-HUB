rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User Profiles: Autorisation pour le propriétaire
    match /users/{userId} {
      // Autoriser la création si l'utilisateur est authentifié avec le même UID
      allow create: if request.auth != null && request.auth.uid == userId;
      // Autoriser la lecture/mise à jour par le propriétaire ou l'admin
      allow read: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow delete: if false; // Suppression manuelle par admin uniquement

      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Stories and Chapters
    match /stories/{storyId} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.resource.data.artistId == request.auth.uid || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      
      match /chapters/{chapterId} {
        allow read: if true;
        allow write: if request.auth != null;
        
        match /comments/{commentId} {
          allow read: if true;
          allow write: if request.auth != null;
        }
      }
      match /likes/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Forums and Clubs
    match /forumThreads/{threadId} {
      allow read: if true;
      allow write: if request.auth != null;
      match /replies/{replyId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
    
    match /readingClubs/{clubId} {
      allow read: if true;
      allow write: if request.auth != null;
      match /members/{memberId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    match /products/{id} { allow read: if true; allow write: if false; }
    match /blogPosts/{id} { allow read: if true; allow write: if false; }
    
    match /liveEvents/{eventId}/messages/{msgId} {
      allow read: if true;
      allow create: if request.auth != null;
    }
    
    match /typing/{convId} {
      allow read, write: if request.auth != null;
    }
    
    match /conversations/{convId}/messages/{msgId} {
      allow read, write: if request.auth != null;
    }
  }
}