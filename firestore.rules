rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // RÈGLES POUR LES HISTOIRES
    match /stories/{storyId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == resource.data.artistId;
    }
    
    // RÈGLES POUR LES UTILISATEURS
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Sous-collection Bibliothèque
      match /library/{storyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Sous-collection Notifications
      match /notifications/{notifId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // RÈGLES POUR LE FORUM (Nécessaire pour le fonctionnement de la page thread)
    match /forumThreads/{threadId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      
      match /replies/{replyId} {
        allow read: if true;
        allow create: if request.auth != null;
      }
    }
  }
}