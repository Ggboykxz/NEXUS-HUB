rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user is accessing their own document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Allow anyone to read all documents (Stories, Chapters, Artist Profiles, etc.)
    // Except for private conversations which are handled below
    match /{document=**} {
      allow read: if true;
    }

    // Specific rules for user profiles to ensure safe creation and updates
    match /users/{userId} {
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId);
    }

    // Rules for sub-collections (Library, Notifications, Favorites)
    match /users/{userId}/library/{storyId} {
      allow write: if isOwner(userId);
    }
    match /users/{userId}/favorites/{storyId} {
      allow write: if isOwner(userId);
    }
    match /users/{userId}/notifications/{notifId} {
      allow write: if isOwner(userId);
    }

    // Messaging System Rules
    match /conversations/{convId} {
      // Allow reading and writing to a conversation if the user is a participant
      allow read, update, delete: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        // Participants of the parent conversation can read/write messages
        allow read, write: if isAuthenticated(); 
      }
    }

    match /typing/{convId} {
      // Typing indicators are accessible to authenticated users
      allow read, write: if isAuthenticated();
    }

    // Live Chat Rules
    match /liveEvents/{eventId}/messages/{messageId} {
      allow read: if true;
      allow create: if isAuthenticated();
    }

    // Generic allow write for other collections if authenticated
    match /stories/{storyId}/{document=**} {
      allow write: if isAuthenticated();
    }
    match /forumThreads/{threadId}/{document=**} {
      allow write: if isAuthenticated();
    }
    match /reports/{reportId} {
      allow create: if true; // Allow anonymous reports
      allow update, delete: if isAuthenticated(); // Admin logic
    }
    
    // Support for awards and festivals
    match /awardNominees/{id} {
      allow write: if isAuthenticated();
    }
    match /festivals/{id} {
      allow write: if isAuthenticated();
    }
  }
}