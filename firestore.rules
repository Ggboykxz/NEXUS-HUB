rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════
//  NEXUSHUB — FIRESTORE SECURITY RULES
//  Version : 1.0.0 — Production
//  Dernière mise à jour : 2025
// ═══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    //  FONCTIONS UTILITAIRES
    // =========================================================================

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return isAuth() && request.auth.token.email_verified == true;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuth() && myProfile().role == role;
    }

    function isAdmin() {
      return isAuth() && myProfile().role == 'admin';
    }

    function isArtist() {
      return isAuth() && myProfile().role in ['artist_draft', 'artist_pro', 'artist_elite'];
    }

    function isNotBanned() {
      return isAuth() && myProfile().get('isBanned', false) == false;
    }

    function getStory(storyId) {
      return get(/databases/$(database)/documents/stories/$(storyId)).data;
    }

    function isStoryOwner(storyId) {
      return isAuth() && getStory(storyId).artistId == request.auth.uid;
    }

    function isTeamMember(storyId) {
      return isAuth() && request.auth.uid in getStory(storyId).get('team', {});
    }

    function canManageStory(storyId) {
      return isStoryOwner(storyId) || isTeamMember(storyId);
    }

    function isParticipant(convId) {
      return isAuth() &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
    }

    function validStr(field, minLen, maxLen) {
      return field is string && field.size() >= minLen && field.size() <= maxLen;
    }

    function validPositiveNumber(field) {
      return field is number && field >= 0;
    }

    function fieldsNotChanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function onlyFieldsChanged(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }


    // =========================================================================
    //  COLLECTION : users
    // =========================================================================

    match /users/{userId} {
      allow read: if true;

      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && validStr(request.resource.data.displayName, 2, 50)
        && validStr(request.resource.data.email, 5, 200)
        && request.resource.data.role in ['reader', 'artist_draft']
        && request.resource.data.afriCoins == 0
        && request.resource.data.isBanned == false
        && request.resource.data.isVerified == false
        && request.resource.data.get('subscribersCount', 0) == 0;

      allow update: if isOwner(userId)
        && isNotBanned()
        && fieldsNotChanged([
          'uid', 'email', 'role', 'afriCoins',
          'isBanned', 'isVerified', 'subscribersCount',
          'level', 'createdAt'
        ])
        && (!('displayName' in request.resource.data.diff(resource.data).affectedKeys())
            || validStr(request.resource.data.displayName, 2, 50))
        && (!('bio' in request.resource.data.diff(resource.data).affectedKeys())
            || validStr(request.resource.data.bio, 0, 1000))
        || isAdmin();

      allow delete: if isAdmin();

      match /library/{storyId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isNotBanned()
          && request.resource.data.storyId == storyId
          && request.resource.data.get('progress', 0) >= 0;
        allow update: if isOwner(userId)
          && fieldsNotChanged(['storyId', 'addedAt']);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /subscriptions/{artistId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isNotBanned()
          && request.resource.data.artistId == artistId;
        allow delete: if isOwner(userId) || isAdmin();
        allow update: if false;
      }
    }


    // =========================================================================
    //  COLLECTION : stories
    // =========================================================================

    match /stories/{storyId} {
      allow read: if (resource.data.isPublished == true && resource.data.isBanned == false)
        || canManageStory(storyId)
        || isAdmin();

      allow create: if isArtist()
        && isEmailVerified()
        && isNotBanned()
        && request.resource.data.artistId == request.auth.uid
        && validStr(request.resource.data.title, 2, 200)
        && validStr(request.resource.data.description, 10, 3000)
        && request.resource.data.format in ['Webtoon', 'BD', 'One-shot', 'Roman Illustré', 'Hybride']
        && request.resource.data.status in ['En cours', 'Terminé', 'À venir']
        && request.resource.data.tier in ['free', 'draft', 'pro', 'premium']
        && request.resource.data.views == 0
        && request.resource.data.likes == 0
        && request.resource.data.subscriptions == 0
        && request.resource.data.chapterCount == 0
        && request.resource.data.isBanned == false
        && request.resource.data.get('isOriginal', false) == false;

      allow update: if canManageStory(storyId)
        && isNotBanned()
        && fieldsNotChanged([
          'artistId', 'isBanned', 'isOriginal',
          'views', 'likes', 'subscriptions', 'chapterCount'
        ])
        || isAdmin();

      allow delete: if isStoryOwner(storyId) || isAdmin();

      match /likes/{userId} {
        allow read: if true;
        allow create: if isOwner(userId) && isNotBanned()
          && request.resource.data.userId == userId;
        allow delete: if isOwner(userId) || isAdmin();
        allow update: if false;
      }

      match /chapters/{chapterId} {
        allow read: if getStory(storyId).isPublished == true
          && getStory(storyId).isBanned == false
          && resource.data.status == 'Publié'
          || canManageStory(storyId)
          || isAdmin();

        allow create: if canManageStory(storyId)
          && isNotBanned()
          && isEmailVerified()
          && request.resource.data.storyId == storyId
          && validStr(request.resource.data.title, 1, 200)
          && request.resource.data.status in ['Publié', 'Programmé', 'Brouillon']
          && request.resource.data.get('views', 0) == 0
          && request.resource.data.get('likes', 0) == 0;

        allow update: if canManageStory(storyId)
          && isNotBanned()
          && fieldsNotChanged(['storyId', 'views', 'likes'])
          || isAdmin();

        allow delete: if isStoryOwner(storyId) || isAdmin();

        match /comments/{commentId} {
          allow read: if resource.data.isHidden == false
            || canManageStory(storyId)
            || isAdmin();

          allow create: if isAuth()
            && isNotBanned()
            && request.resource.data.authorId == request.auth.uid
            && validStr(request.resource.data.content, 1, 2000)
            && request.resource.data.likes == 0
            && request.resource.data.isHidden == false
            && request.resource.data.isEdited == false
            && (!('pageIndex' in request.resource.data)
                || (request.resource.data.pageIndex is int
                    && request.resource.data.pageIndex >= 0));

          allow update: if (isOwner(resource.data.authorId)
              && isNotBanned()
              && onlyFieldsChanged(['content', 'isEdited', 'updatedAt'])
              && validStr(request.resource.data.content, 1, 2000))
            || (canManageStory(storyId)
              && onlyFieldsChanged(['isHidden', 'updatedAt']))
            || isAdmin();

          allow delete: if isOwner(resource.data.authorId)
            || canManageStory(storyId)
            || isAdmin();
        }
      }
    }


    // =========================================================================
    //  COLLECTION : forums
    // =========================================================================

    match /forums/{forumId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /threads/{threadId} {
        allow read: if resource.data.get('isHidden', false) == false || isAdmin();

        allow create: if isAuth()
          && isNotBanned()
          && request.resource.data.authorId == request.auth.uid
          && validStr(request.resource.data.title, 5, 200)
          && validStr(request.resource.data.content, 10, 10000)
          && request.resource.data.get('views', 0) == 0
          && request.resource.data.get('replyCount', 0) == 0
          && request.resource.data.isPinned == false
          && request.resource.data.isLocked == false
          && request.resource.data.get('isHidden', false) == false
          && (get(/databases/$(database)/documents/forums/$(forumId)).data.get('isRestricted', false) == false
              || isArtist());

        allow update: if (isOwner(resource.data.authorId)
            && isNotBanned()
            && resource.data.isLocked == false
            && fieldsNotChanged([
              'authorId', 'isPinned', 'isLocked',
              'isHidden', 'views', 'replyCount'
            ]))
          || isAdmin();

        allow delete: if isOwner(resource.data.authorId) || isAdmin();

        match /posts/{postId} {
          allow read: if resource.data.get('isHidden', false) == false || isAdmin();

          allow create: if isAuth()
            && isNotBanned()
            && get(/databases/$(database)/documents/forums/$(forumId)/threads/$(threadId)).data.isLocked == false
            && request.resource.data.authorId == request.auth.uid
            && validStr(request.resource.data.content, 1, 10000)
            && request.resource.data.get('likes', 0) == 0
            && request.resource.data.get('isHidden', false) == false;

          allow update: if (isOwner(resource.data.authorId)
              && isNotBanned()
              && onlyFieldsChanged(['content', 'isEdited', 'updatedAt'])
              && validStr(request.resource.data.content, 1, 10000))
            || isAdmin();

          allow delete: if isOwner(resource.data.authorId) || isAdmin();
        }
      }
    }


    // =========================================================================
    //  COLLECTION : conversations
    // =========================================================================

    match /conversations/{convId} {
      allow read: if isParticipant(convId);

      allow create: if isAuth()
        && isNotBanned()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() >= 2
        && request.resource.data.participants.size() <= 50;

      allow update: if isParticipant(convId)
        && isNotBanned()
        && fieldsNotChanged(['participants', 'createdAt', 'isGroup']);

      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isParticipant(convId);

        allow create: if isParticipant(convId)
          && isNotBanned()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.type in ['text', 'image', 'africoins', 'sticker']
          && validStr(request.resource.data.content, 1, 5000)
          && request.resource.data.get('isDeleted', false) == false;

        allow update: if isOwner(resource.data.authorId)
          && onlyFieldsChanged(['isDeleted', 'updatedAt'])
          || isAdmin();

        allow delete: if isAdmin();
      }
    }


    // =========================================================================
    //  COLLECTION : notifications
    // =========================================================================

    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if false;
      allow update: if isOwner(resource.data.userId)
        && onlyFieldsChanged(['isRead', 'readAt'])
        && request.resource.data.isRead == true;
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }


    // =========================================================================
    //  COLLECTION : transactions
    // =========================================================================

    match /transactions/{txId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create, update, delete: if false;
    }


    // =========================================================================
    //  COLLECTION : playlists
    // =========================================================================

    match /playlists/{playlistId} {
      allow read: if resource.data.isPublic == true
        || isOwner(resource.data.ownerId)
        || isAdmin();

      allow create: if isAuth()
        && isNotBanned()
        && request.resource.data.ownerId == request.auth.uid
        && validStr(request.resource.data.title, 1, 100)
        && request.resource.data.get('storyCount', 0) == 0;

      allow update: if isOwner(resource.data.ownerId)
        && isNotBanned()
        && fieldsNotChanged(['ownerId', 'createdAt']);

      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }


    // =========================================================================
    //  COLLECTION : products
    // =========================================================================

    match /products/{productId} {
      allow read: if resource.data.isAvailable == true
        || (isAuth() && resource.data.artistId == request.auth.uid)
        || isAdmin();

      allow create: if isArtist()
        && isEmailVerified()
        && isNotBanned()
        && request.resource.data.artistId == request.auth.uid
        && validStr(request.resource.data.name, 2, 200)
        && validPositiveNumber(request.resource.data.price)
        && request.resource.data.category in [
          'tshirt', 'poster', 'ebook', 'artprint',
          'goodies', 'sticker', 'mug'
        ];

      allow update: if (isArtist() && resource.data.artistId == request.auth.uid
        && isNotBanned()
        && fieldsNotChanged(['artistId', 'createdAt']))
        || isAdmin();

      allow delete: if (isArtist() && resource.data.artistId == request.auth.uid)
        || isAdmin();
    }


    // =========================================================================
    //  COLLECTION : orders
    // =========================================================================

    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }


    // =========================================================================
    //  COLLECTION : reports
    // =========================================================================

    match /reports/{reportId} {
      allow read: if isOwner(resource.data.reporterId) || isAdmin();

      allow create: if isAuth()
        && isNotBanned()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.targetType in [
          'story', 'chapter', 'comment', 'user', 'post', 'thread', 'message'
        ]
        && validStr(request.resource.data.reason, 5, 1000)
        && request.resource.data.get('status', 'pending') == 'pending';

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }


    // =========================================================================
    //  COLLECTION : bans
    // =========================================================================

    match /bans/{banId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create, update, delete: if isAdmin();
    }


    // =========================================================================
    //  COLLECTION : africoins_packages
    // =========================================================================

    match /africoins_packages/{packageId} {
      allow read: if true;
      allow write: if isAdmin();
    }


    match /{document=**} {
      allow read, write: if false;
    }

  }
}