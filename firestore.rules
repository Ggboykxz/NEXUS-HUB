rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Allow public read access to stories
    match /stories/{storyId} {
      allow read: if true;
      allow write: if isAuthenticated(); // Keep original write rule
    }
    
    // Allow public read access to most documents
    match /{document=**} {
      allow read: if true;
    }

    match /users/{userId} {
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      
      // Sub-collections
      match /library/{storyId} {
        allow write: if isOwner(userId);
      }
      match /favorites/{storyId} {
        allow write: if isOwner(userId);
      }
      match /notifications/{notifId} {
        allow write: if isOwner(userId);
      }
    }

    match /conversations/{convId} {
      allow read, update, delete: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }

    match /typing/{convId} {
      allow read, write: if isAuthenticated();
    }

    match /liveEvents/{eventId}/messages/{messageId} {
      allow read: if true;
      allow create: if isAuthenticated();
    }

    match /forumThreads/{threadId}/{document=**} {
      allow write: if isAuthenticated();
    }

    match /reports/{reportId} {
      allow create: if true;
      allow update, delete: if isAuthenticated();
    }
    
    match /awardNominees/{id} {
      allow write: if isAuthenticated();
    }
    
    match /festivals/{id} {
      allow write: if isAuthenticated();
    }
  }
}