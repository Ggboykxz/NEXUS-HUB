rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User Profiles
    match /users/{userId} {
      // Autorise la lecture pour tous les utilisateurs connectés
      allow read: if request.auth != null;
      
      // Autorise la création et la mise à jour si l'utilisateur est le propriétaire
      allow write: if request.auth != null && request.auth.uid == userId;

      // Match all sub-collections belonging to a user
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Stories and Chapters
    match /stories/{storyId} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.resource.data.artistId == request.auth.uid || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      
      match /chapters/{chapterId} {
        allow read: if true;
        allow write: if request.auth != null;
        
        match /comments/{commentId} {
          allow read: if true;
          allow write: if request.auth != null;
        }
      }
      match /likes/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Reports (Admin only for management)
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Forums and Clubs
    match /forumThreads/{threadId} {
      allow read: if true;
      allow write: if request.auth != null;
      match /replies/{replyId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
    
    match /readingClubs/{clubId} {
      allow read: if true;
      allow write: if request.auth != null;
      match /members/{memberId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
      match /discussions/{discId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
      match /fanArts/{artId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Public Collections
    match /products/{id} { allow read: if true; allow write: if false; }
    match /blogPosts/{id} { allow read: if true; allow write: if false; }
    
    // Typing status
    match /typing/{convId} {
      allow read, write: if request.auth != null;
    }
    
    // Live events
    match /liveEvents/{eventId}/messages/{msgId} {
      allow read: if true;
      allow create: if request.auth != null;
    }
  }
}